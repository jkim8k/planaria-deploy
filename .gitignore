__pycache__/
*.pyc
.venv/
.uv-cache/
.tmp_eval/
logs/
*.log
.claude/

# ── Secret / credential files (must never be tracked) ──
secrets.json
key_config.json
.env
.env.*

# ── All runtime workspaces are local-only. ──
# workspace_default/ is kept as a skeleton sample so install.sh has a base
# layout to copy from. Everything else is gitignored so real credentials,
# memory, and logs never leak into git history.
workspace_*/
!workspace_default/
workspace_default/memory/
workspace_default/data/
workspace_default/logs/
workspace_default/secrets.json
